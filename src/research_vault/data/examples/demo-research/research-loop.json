    },
    {
      "id": "q1-main1-run-register",
      "type": "tool",
      "op": "register_provenance",
      "label": "Register PRODUCED provenance edge — q1-main1 run artifact",
      "args": {
        "project": "demo-research",
        "edges": [
          {
            "kind": "artifact",
            "source_type": "experiments", "source_id": "q1-main1",
            "tag": "PRODUCED", "reason": "q1-main1's run artifact",
            "artifact": "results/runs/q1-main1.jsonl"
