    {
      "id": "human-go-harness-main1",
      "type": "human-go",
      "label": "Human approval gate — Main 1 harness reviewed and accepted. Run: rv plan freeze-harness <run_id> <plan-note> --scope main1 --harness-commit <sha>",
      "needs": [{"from": "q1-main1-harness-review", "edge": "afterok"}]
